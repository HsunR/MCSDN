<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.TagMapper">
    <select id="findAll" resultType="com.blog.entity.Tag">
        SELECT id, name, created_at FROM tags ORDER BY name
    </select>

    <select id="findById" resultType="com.blog.entity.Tag">
        SELECT id, name, created_at FROM tags WHERE id = #{id}
    </select>

    <select id="findByName" resultType="com.blog.entity.Tag">
        SELECT id, name, created_at FROM tags WHERE name = #{name}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tags (name) VALUES (#{name})
    </insert>

    <delete id="delete">
        DELETE FROM tags WHERE id = #{id}
    </delete>
</mapper>
